# =========================================================
# LAB C2 IPS PRE-BLOCK RULES - SNORT 3 VALID SYNTAX
# Windows Client: 192.168.100.20
# Fake C2 Server / INetSim: 10.10.10.20
#
# Purpose:
# - Known C2-like behaviors are blocked immediately.
# - Unknown behaviors are handled later by Zeek + Python auto rules.
# =========================================================

# ---------------------------------------------------------
# 0A. Background allowlist: keep Windows system traffic out of C2 demo blocks
# ---------------------------------------------------------
pass tcp 192.168.100.0/24 any -> any any (
    msg:"LAB-PASS benign Windows Update certificate checks";
    flow:to_server,established;
    http_header;
    content:"Host|3A|",nocase;
    content:"ctldl.windowsupdate.com",nocase;
    sid:2099001;
    rev:1;
)

pass tcp 192.168.100.0/24 any -> any any (
    msg:"LAB-PASS benign Microsoft connectivity test";
    flow:to_server,established;
    http_header;
    content:"Host|3A|",nocase;
    content:"www.msftconnecttest.com",nocase;
    sid:2099002;
    rev:1;
)

# ---------------------------------------------------------
# 0. Visibility rule: alert HTTP traffic to Fake C2
# ---------------------------------------------------------
alert tcp 192.168.100.0/24 any -> 10.10.10.20 80 (
    msg:"LAB-IPS OBSERVE HTTP traffic to Fake C2 IP";
    flow:to_server,established;
    sid:2100001;
    rev:1;
)

alert udp 192.168.100.0/24 any -> 10.10.10.20 53 (
    msg:"LAB-IPS OBSERVE DNS request no Snort block";
    sid:2100002;
    rev:1;
)

alert tcp 192.168.100.0/24 any -> 10.10.10.20 53 (
    msg:"LAB-IPS OBSERVE DNS request no Snort block TCP";
    flow:to_server,established;
    sid:2100003;
    rev:1;
)

alert icmp 192.168.100.0/24 any -> 10.10.10.20 any (
    msg:"LAB-IPS OBSERVE ICMP ping no Snort block";
    sid:2100004;
    rev:1;
)

alert tcp 192.168.100.0/24 any -> 10.10.10.20 [21,25,110,143,587,993,995,8080,8443,8888,9001] (
    msg:"LAB-IPS OBSERVE TCP service request no Snort block";
    flow:to_server,established;
    sid:2100005;
    rev:1;
)

alert udp 192.168.100.0/24 any -> 10.10.10.20 [69,123,500,4500] (
    msg:"LAB-IPS OBSERVE UDP service request no Snort block";
    sid:2100006;
    rev:1;
)

