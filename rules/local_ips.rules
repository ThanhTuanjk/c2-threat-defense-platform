# ===== ENTERPRISE-LITE MALWARE C2 RULE PACK V2 =====
# Purpose:
# - Catch common malware C2 behaviors without relying only on obvious lab keywords.
# - Strong indicators are blocked.
# - Weak indicators are alerted for correlation.

# ---------------------------------------------------------
# 1. Common HTTP C2 endpoint names
# ---------------------------------------------------------
block tcp 192.168.100.0/24 any -> any any (
    msg:"ENT-V2 BLOCK common HTTP C2 endpoint";
    flow:to_server,established;
    http_uri;
    pcre:"/\/(gate|gates|beacon|checkin|callback|connect|panel|task|command|cmd|loader|payload|update|upload|exfil|collect|dump|steal|keylog|screenshot)(\.php|\.asp|\.aspx|\.jsp|\.cgi)?(\?|\/|$)/i";
    sid:2201001;
    rev:1;
)

# ---------------------------------------------------------
# 2. Suspicious bot/victim identifiers in URI
# Alert only because some apps use id/token normally.
# ---------------------------------------------------------
alert tcp 192.168.100.0/24 any -> any any (
    msg:"ENT-V2 OBSERVE possible bot/victim identifier in HTTP URI";
    flow:to_server,established;
    http_uri;
    pcre:"/[?&](bot|bot_id|victim|hwid|guid|uuid|uid|machine|hostname|username|campaign|session|token|key)=/i";
    sid:2201002;
    rev:1;
)

# ---------------------------------------------------------
# 3. PowerShell encoded command in HTTP body
# ---------------------------------------------------------
block tcp 192.168.100.0/24 any -> any any (
    msg:"ENT-V2 BLOCK PowerShell encoded command in HTTP body";
    flow:to_server,established;
    http_client_body;
    pcre:"/(powershell|pwsh).{0,120}(-enc|-encodedcommand|frombase64string|invoke-expression|iex)/i";
    sid:2201003;
    rev:1;
)

# ---------------------------------------------------------
# 4. Command/control parameters in HTTP body
# ---------------------------------------------------------
alert tcp 192.168.100.0/24 any -> any any (
    msg:"ENT-V2 OBSERVE command-like parameter in HTTP body";
    flow:to_server,established;
    http_client_body;
    pcre:"/(cmd=|command=|exec=|shell=|task=|run=|payload=|download=|upload=)/i";
    sid:2201004;
    rev:1;
)

# ---------------------------------------------------------
# 5. Dangerous payload download extensions
# In malware sandbox, block outbound payload downloads.
# ---------------------------------------------------------
block tcp 192.168.100.0/24 any -> any any (
    msg:"ENT-V2 BLOCK dangerous payload download extension";
    flow:to_server,established;
    http_uri;
    pcre:"/\.(exe|dll|ps1|vbs|vbe|js|jse|hta|bat|cmd|scr|msi|jar|lnk|iso|cab)(\?|$)/i";
    sid:2201005;
    rev:1;
)

# ---------------------------------------------------------
# 6. Suspicious automation User-Agent
# Alert only if standalone.
# ---------------------------------------------------------
alert tcp 192.168.100.0/24 any -> any any (
    msg:"ENT-V2 OBSERVE suspicious automation User-Agent";
    flow:to_server,established;
    http_header;
    pcre:"/User-Agent\x3a[^\r\n]*(PowerShell|python-requests|curl|Wget|Go-http-client|WinHTTP|BITS|Microsoft BITS)/i";
    sid:2201006;
    rev:1;
)

# ---------------------------------------------------------
# 7. Suspicious UA combined with C2 URI
# ---------------------------------------------------------

# ---------------------------------------------------------
# 8. Credential/token/cookie exfil-like body
# Alert because many apps also send tokens.
# ---------------------------------------------------------
alert tcp 192.168.100.0/24 any -> any any (
    msg:"ENT-V2 OBSERVE possible credential/token exfil in HTTP body";
    flow:to_server,established;
    http_client_body;
    pcre:"/(password=|passwd=|pwd=|token=|access_token=|cookie=|sessionid=|wallet|clipboard|keylog|screenshot)/i";
    sid:2201008;
    rev:1;
)

# ---------------------------------------------------------
# 9. Encoded-looking DNS label, possible DGA/DNS tunneling
# ---------------------------------------------------------
block udp 192.168.100.0/24 any -> any 53 (
    msg:"ENT-V2 BLOCK encoded-looking DNS label possible DGA/tunnel";
    pcre:"/[A-Za-z0-9_-]{32,}\./";
    sid:2201101;
    rev:1;
)

# ---------------------------------------------------------
# 10. DNS weak malware words: alert only
# ---------------------------------------------------------
alert udp 192.168.100.0/24 any -> any 53 (
    msg:"ENT-V2 OBSERVE DNS weak malware keyword";
    pcre:"/(c2|evil|beacon|botnet|malware|payload|command)/i";
    sid:2201102;
    rev:1;
)

# ---------------------------------------------------------
# 11. QUIC/HTTP3 UDP 443 can bypass HTTP inspection in sandbox
# ---------------------------------------------------------
block udp 192.168.100.0/24 any -> any 443 (
    msg:"ENT-V2 BLOCK UDP 443 QUIC/HTTP3 possible encrypted C2 bypass";
    sid:2201201;
    rev:1;
)

# ---------------------------------------------------------
# 12. DNS-over-TLS port 853
# ---------------------------------------------------------
block tcp 192.168.100.0/24 any -> any 853 (
    msg:"ENT-V2 BLOCK DNS-over-TLS TCP 853";
    sid:2201202;
    rev:1;
)

block udp 192.168.100.0/24 any -> any 853 (
    msg:"ENT-V2 BLOCK DNS-over-TLS UDP 853";
    sid:2201203;
    rev:1;
)

# ---------------------------------------------------------
# 13. Non-standard web/C2 ports: alert for correlation
# ---------------------------------------------------------
alert tcp 192.168.100.0/24 any -> any [8080,8443,8000,8888,4443,9001] (
    msg:"ENT-V2 OBSERVE outbound non-standard web/C2 port";
    flow:to_server,established;
    sid:2201204;
    rev:1;
)

# ===== END ENTERPRISE-LITE MALWARE C2 RULE PACK V2 =====

