# =========================================================
# IPS Behavioral Rule: Go-http-client repeated generate_204
# Evidence:
# - Windows endpoint repeatedly sends HTTP GET /generate_204
# - User-Agent: Go-http-client/1.1
# - Repeats within 5 minutes, beacon-like behavior
# MITRE: T1071.001 Web Protocols
# =========================================================
block tcp 192.168.100.0/24 any -> any 56001,56002,56003 (
    msg:"IPS-BLOCK repeated Go-http-client generate_204 beacon-like HTTP";
    flow:to_server,established;
    http_header;
    content:"User-Agent|3A|",nocase;
    content:"Go-http-client",nocase;
    http_uri;
    content:"/generate_204",nocase;
    detection_filter:track by_src, count 5, seconds 300;
    classtype:trojan-activity;
    sid:2219010;
    rev:1;
)


# Malware custom high-port C2 observed from Windows lab client
block tcp 192.168.100.0/24 any -> any [56001,56002,56003] (msg:"LAB-IPS BLOCK malware custom C2 high-port traffic 56001-56003"; flow:to_server; sid:2100200; rev:1;)

