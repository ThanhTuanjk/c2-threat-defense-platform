# =========================================================
# 8. High-risk outbound protocols in lab
# These are commonly abused for C2 or exfiltration.
# =========================================================

alert tcp 192.168.100.0/24 any -> any 6667 (
    msg:"IDS-DETECT possible IRC C2 outbound";
    flow:to_server,established;
    sid:2100801;
    rev:1;
)

alert tcp 192.168.100.0/24 any -> any 21 (
    msg:"IDS-DETECT possible FTP exfil outbound";
    flow:to_server,established;
    sid:2100802;
    rev:1;
)

alert tcp 192.168.100.0/24 any -> any 25 (
    msg:"IDS-DETECT possible SMTP exfil outbound";
    flow:to_server,established;
    sid:2100803;
    rev:1;
)

alert tcp 192.168.100.0/24 any -> any 587 (
    msg:"IDS-DETECT possible SMTP submission exfil outbound";
    flow:to_server,established;
    sid:2100804;
    rev:1;
)


# Malware custom high-port C2 observed from Windows lab client
alert tcp 192.168.100.0/24 any -> any [56001,56002,56003] (msg:"LAB-IDS ALERT malware custom C2 high-port traffic 56001-56003"; flow:to_server; sid:2100200; rev:1;)
