# =========================================================
# 2. Beacon patterns
# =========================================================

alert tcp 192.168.100.0/24 any -> any any (
    msg:"IDS-DETECT C2 beacon status online";
    flow:to_server,established;
    http_uri;
    content:"/beacon.php",nocase;
    content:"status=online",nocase;
    sid:2100201;
    rev:1;
)

alert tcp 192.168.100.0/24 any -> any any (
    msg:"IDS-DETECT C2 beacon with id and online status";
    flow:to_server,established;
    http_uri;
    pcre:"/\/beacon\.php\?id=[A-Za-z0-9_-]+&status=online/i";
    sid:2100202;
    rev:1;
)

alert tcp 192.168.100.0/24 any -> any any (
    msg:"IDS-DETECT C2 bot id in URI";
    flow:to_server,established;
    http_uri;
    content:"bot_id=",nocase;
    sid:2100203;
    rev:1;
)

alert tcp 192.168.100.0/24 any -> any any (
    msg:"IDS-DETECT C2 victim id in URI";
    flow:to_server,established;
    http_uri;
    content:"victim=",nocase;
    sid:2100204;
    rev:1;
)

