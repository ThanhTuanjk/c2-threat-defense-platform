# =========================================================
# LAB C2 IPS IDS-DETECT RULES - SNORT 3 VALID SYNTAX
# Windows Client: 192.168.100.20
# Fake C2 Server / INetSim: 10.10.10.20
#
# Purpose:
# - Known C2-like behaviors are blocked immediately.
# - Unknown behaviors are handled later by Zeek + Python auto rules.
# =========================================================

# ---------------------------------------------------------
# 0. Visibility rule: alert HTTP traffic to Fake C2
# ---------------------------------------------------------
alert tcp 192.168.100.0/24 any -> 10.10.10.20 80 (
    msg:"LAB-IDS OBSERVE HTTP traffic to Fake C2 IP";
    flow:to_server,established;
    sid:2100001;
    rev:1;
)

# =========================================================
# 1. Known C2 URI / check-in / beacon endpoints
# =========================================================

alert tcp 192.168.100.0/24 any -> any any (
    msg:"IDS-DETECT C2 URI /gate.php";
    flow:to_server,established;
    http_uri;
    content:"/gate.php",nocase;
    sid:2100101;
    rev:1;
)

alert tcp 192.168.100.0/24 any -> any any (
    msg:"IDS-DETECT C2 URI /beacon.php";
    flow:to_server,established;
