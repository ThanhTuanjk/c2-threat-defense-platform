def handle_notice(rec):
    note = rec.get("note", "-")
    if note != "LabPreL7::Suspicious_Connection_Attempt":
        return

    ts = rec.get("ts", "-")
    uid = rec.get("uid", "-")
    src = rec.get("src", rec.get("id.orig_h", "-"))
    dst = rec.get("dst", rec.get("id.resp_h", "-"))
    dport = rec.get("p", rec.get("id.resp_p", "-"))
    msg = rec.get("msg", "-")

    key = f"notice|{uid}|{ts}|{src}|{dst}|{dport}|{note}"
    if key in SHOWN:
        return
    SHOWN.add(key)

    rows = [
        ("Time", now_str(ts)),
        ("Event type", "Suspicious TCP connection attempt"),
        ("Severity", "HIGH"),
        ("Action", "OBSERVED BY ZEEK / CHECK SNORT VERDICT"),
        ("Source IP", src),
        ("Destination", dst),
        ("Destination port", dport),
        ("Zeek UID", uid),
        ("Evidence", msg),
        ("Layer-7 status", "Not established yet"),
        ("MITRE mapping", "T1071 possible"),
        ("Result", "Zeek captured the real ingress connection attempt on ens33. Match this flow and time with Snort to confirm BLOCK/DROP."),
    ]

    box("ZEEK PRE-L7 SUSPICIOUS CONNECTION OBSERVED", rows)

def main():
    http_tail = ZeekTail(ZEEK_DIR / "http.log", "http")
    dns_tail = ZeekTail(ZEEK_DIR / "dns.log", "dns")
    notice_tail = ZeekTail(ZEEK_DIR / "notice.log", "notice")

    print(f"[ZEEK VIEW] Watching Zeek directory: {ZEEK_DIR}", flush=True)
    print("[ZEEK VIEW] Pre-L7 C2 attempts come from Zeek notice.log; Snort remains authoritative for DROP verdicts.", flush=True)
    print("[ZEEK VIEW] HTTP Status '-' means request was seen but no completed HTTP response was observed.", flush=True)
    print("[ZEEK VIEW] Correlate 'NO HTTP RESPONSE' with Snort BLOCK and Windows timeout to prove IPS blocking.", flush=True)

    while True:
        for rec in http_tail.poll():
            handle_http(rec)

        for rec in dns_tail.poll():
            handle_dns(rec)

        for rec in notice_tail.poll():
            handle_notice(rec)

        time.sleep(0.2)

if __name__ == "__main__":
    main()
