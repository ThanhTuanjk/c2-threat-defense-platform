        ("Suspicion score", score),
        ("Reasons", ",".join(reasons) if reasons else "-"),
        ("Suspected type", suspected),
        ("MITRE mapping", mitre),
        ("Result", result),
    ]

    box(title, rows)

def dns_score(query):
    q = query.lower()
    score = 0
    reasons = []

    if len(query) >= 45:
        score += 2
        reasons.append("long_domain")

    if is_encoded_like_label(query):
        score += 3
        reasons.append("encoded_like_label")

    for kw in ["c2", "bot", "malware", "payload", "beacon", "evil", "auto-lab"]:
        if kw in q:
            score += 2
            reasons.append(f"keyword:{kw}")

    return score, reasons

def handle_dns(rec):
    ts = rec.get("ts", "-")
    uid = rec.get("uid", "-")
    src = rec.get("id.orig_h", "-")
    query = rec.get("query", "-")
    rcode = rec.get("rcode_name", "-")
    answers = rec.get("answers", "-")

    key = f"dns|{uid}|{src}|{query}|{rcode}|{answers}"
    if key in SHOWN:
        return
    SHOWN.add(key)

    score, reasons = dns_score(query)

    if score >= 3:
        title = "ZEEK DNS SUSPICIOUS TRAFFIC"
        event_type = "Suspicious DNS query"
        severity = "MEDIUM"
        action = "DNS OBSERVED / POSSIBLE C2 INDICATOR"
        suspected = "Possible DNS C2 / encoded domain"
        mitre = "T1071.004 DNS / T1568 Dynamic Resolution"
        result = "Suspicious DNS query observed by Zeek. Use with Snort/Python evidence for correlation."
